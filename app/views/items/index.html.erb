<h1 class="page-title">必要アイテム数</h1>

<div class="items-search-row">
  <div>
    <% if user_signed_in? %>
      <strong><%= current_user.email %></strong>
    <% else %>
      <strong>ゲスト</strong>
    <% end %>
  </div>

  <%= form_with url: items_path, method: :get, local: true, class: "items-search-form" do %>
    <%= label_tag :q, "検索" %>
    <%= text_field_tag :q, @q, id: "item-search", placeholder: "アイテム名" %>
  <% end %>
</div>

<div class="items-table-wrapper">
  <% if @items.any? %>
    <table class="items-table">
      <thead>
        <tr>
          <th>アイテム名</th>
          <th>現状数</th>
          <th>必要数</th>
          <th>比較結果</th>
          <th>用途</th>
        </tr>
      </thead>
      <tbody>
        <% @items.each do |item| %>
          <% user_item = @user_items_by_item_id[item.id] %>
          <% current_quantity = user_item&.quantity || 0 %>
          <% required_quantity = item.total_required_quantity %>
          <% usage_text = item.usage_labels.join("/") %>

          <tr>
            <td>
              <%= link_to item.name, item_path(item), class: "item-name-link" %>
            </td>

            <td>
              <% if user_signed_in? %>
                <%= form_with url: user_item_path(item_id: item.id), method: :patch, local: true, class: "quantity-form" do |f| %>
                  <%= f.number_field :quantity, value: current_quantity, min: 0, name: "user_item[quantity]" %>
                  <%= f.submit "更新", class: "simple-button" %>
                <% end %>
              <% else %>
                <span class="login-guide">ログインしてください</span>
              <% end %>
            </td>

            <td><%= required_quantity %></td>

            <td>
              <% if user_signed_in? %>
                <% if current_quantity >= required_quantity %>
                  必要数達成
                <% else %>
                  まだ必要
                <% end %>
              <% else %>
                ログインしてください
              <% end %>
            </td>

            <td><%= usage_text.presence || "-" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>該当するアイテムがありません。</p>
  <% end %>
</div>
