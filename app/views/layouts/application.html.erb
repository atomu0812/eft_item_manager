<!DOCTYPE html>
<html>
  <head>
    <title>EftItemManager</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <div class="header-inner">
        <div class="header-logo">
          <%= link_to "EFT manager", root_path %>
        </div>

        <nav class="header-nav">
          <%= link_to "使い方", guide_path, class: "header-button" %>

          <% if user_signed_in? %>
            <div class="header-dropdown">
              <button type="button" class="header-button header-dropdown-button">
                機能一覧 ▼
              </button>

              <div class="header-dropdown-menu">
                <%= link_to "アイテム一覧", items_path %>
                <%= link_to "不足アイテム一覧", deficit_items_path %>
                <%= link_to "タスク一覧", tasks_path %>

                <% if current_user.admin? %>
                  <%= link_to "管理画面", admin_root_path %>
                <% end %>
              </div>
            </div>

            <% unless current_user.guest? %>
              <%= link_to "ユーザー情報編集", edit_user_registration_path, class: "header-button" %>
            <% end %>

            <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete }, class: "header-button" %>
          <% else %>
            <%= link_to "新規登録", new_user_registration_path, class: "header-button" %>
            <%= link_to "ログイン", new_user_session_path, class: "header-button" %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="page-container">
      <% if notice.present? %>
        <p class="flash-message notice"><%= notice %></p>
      <% end %>

      <% if alert.present? %>
        <p class="flash-message alert"><%= alert %></p>
      <% end %>

      <%= yield %>
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <%= link_to "利用規約", terms_path %>
        <span>|</span>
        <%= link_to "プライバシーポリシー", privacy_path %>
      </div>
    </footer>
  </body>
</html>